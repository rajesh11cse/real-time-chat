{
  "//_comment": "monorepo root package.json for chat system",
  "name": "realtime-chat-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend/*",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build -w backend/user-service && npm run build -w backend/chat-service && npm run build -w frontend",
    "start:user": "npm run start -w backend/user-service",
    "start:chat": "npm run start -w backend/chat-service",
    "start:frontend": "npm run dev -w frontend",
    "lint": "echo \"TODO: add lint scripts\"",
    "test": "echo \"TODO: add root tests\"",
    "test:e2e": "jest --config jest.config.cjs --runInBand"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "ts-jest": "^29.2.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "graphql-ws": "^5.16.0",
    "ws": "^8.18.0"
  }
}
